# Database
# Local dev (SQLite):
DATABASE_URL=sqlite:///./swordoku.db
# Docker (PostgreSQL) — docker-compose overrides this automatically:
# DATABASE_URL=postgresql://swordoku:swordoku@db:5432/swordoku

# JWT — CHANGE THIS before running in any shared environment
SECRET_KEY=change-me-to-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
